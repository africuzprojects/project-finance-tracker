# Copy this file to .env and fill in YOUR values. Never commit .env.
# Then run: npm run build  (writes js/env.generated.js for local / Capacitor)
#
# On Vercel: Project → Settings → Environment Variables:
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#
# The anon key is for the browser/app client only; protect data with Row Level Security.
# Never put the service_role key in the app or in this repo.

SUPABASE_URL=
SUPABASE_ANON_KEY=
